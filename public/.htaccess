DirectoryIndex index.php
Options -Indexes

RewriteEngine On
RewriteRule ^sitemap\.xml$ /sitemap.php [L]

# covenantblog.us (root) redirects to www.covenantblog.us at the DNS/registrar level
# (IONOS doesn't allow a CNAME at the apex). Do not redirect www -> root here,
# or it will loop against that registrar-level redirect.
